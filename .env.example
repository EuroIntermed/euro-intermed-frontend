# Frontend environment — copy to .env. NEVER put secrets here: every VITE_*
# value is shipped to the browser. Only public config belongs in this file.

# Base URL of the backend API (no trailing slash). Matches the backend PORT.
VITE_API_URL=http://localhost:8080

# Public URL of the privacy policy, linked from the GDPR consent notice shown in
# the chat widget + hosted chat. Build-time fallback; an embed may override it
# per host via the widget config `privacyUrl`. Leave unset to render a "#"
# placeholder (the consent text still shows).
VITE_PRIVACY_URL=
